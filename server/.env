# Server
# Port 5000 is taken by macOS ControlCenter (AirPlay Receiver), so use 5001
PORT=5001
NODE_ENV=development

# MongoDB — local instance (default). The Atlas string below fails auth ("bad auth");
# restore/replace it with valid Atlas credentials when deploying.
MONGODB_URI=mongodb://127.0.0.1:27017/lumaris
# MONGODB_URI=mongodb+srv://CortexDevTech:RG6tHBQIHHfWvWp4@cortexdevtech.ayivvns.mongodb.net/lumaris?retryWrites=true&w=majority&appName=CortexDevTech

# JWT — Change this to a long random string in production
JWT_SECRET=lumaris_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=30d

# Stripe Payment — Replace with your actual Stripe keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary Image Uploads — Replace with your Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail SMTP) — Replace with your email credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Lumaris <noreply@lumaris.com>

# Client URL
CLIENT_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@lumaris.com
